      "options": [
        { "value": "illness", "label": "Signs of illness" },
        { "value": "travel", "label": "Travel or change of environment" },
        { "value": "routine_change", "label": "Routine change" },
        { "value": "caregiver_change", "label": "New caregiver" },
        { "value": "developmental", "label": "New skills emerging (growth spurt, leap)" },
        { "value": "nothing_obvious", "label": "Nothing obvious" }
      ]
